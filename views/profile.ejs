<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile - <%= user.name %></title>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0f0f13;
            --bg-secondary: #17171f;
            --bg-card: #1e1e28;
            --bg-card-hover: #23232e;
            --accent-purple: #7c5cbf;
            --accent-purple-bright: #9b7fe8;
            --accent-purple-glow: rgba(124, 92, 191, 0.15);
            --text-primary: #f0f0f5;
            --text-secondary: #8888a0;
            --text-muted: #55556a;
            --border: rgba(255,255,255,0.06);
            --border-hover: rgba(124, 92, 191, 0.4);
            --red: #e05252;
            --green: #4caf82;
            --blue: #5b9cf6;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            padding: 0 0 60px 0;
        }

        /* ── NAVBAR ── */
        .navbar {
            background: rgba(15, 15, 19, 0.85);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            padding: 0 48px;
            height: 68px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar-logo {
            font-family: 'Syne', sans-serif;
            font-size: 22px;
            font-weight: 800;
            letter-spacing: -0.5px;
            color: var(--text-primary);
        }

        .navbar-logo span {
            color: var(--accent-purple-bright);
        }

        .navbar-nav {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .navbar-nav a {
            text-decoration: none;
            color: var(--text-secondary);
            font-size: 14px;
            font-weight: 500;
            padding: 8px 16px;
            border-radius: 8px;
            transition: all 0.2s;
        }

        .navbar-nav a:hover,
        .navbar-nav a.active {
            color: var(--text-primary);
            background: var(--bg-card);
        }

        .navbar-nav a.active {
            font-weight: 600;
        }

        .logout-btn {
            background: transparent;
            color: var(--red);
            border: 1.5px solid var(--red);
            padding: 7px 18px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
            transition: all 0.2s;
            margin-left: 6px;
        }

        .logout-btn:hover {
            background: var(--red);
            color: white;
        }

        /* ── PAGE LAYOUT ── */
        .page {
            max-width: 860px;
            margin: 0 auto;
            padding: 48px 24px 0;
        }

        /* ── PAGE HEADER ── */
        .page-heading {
            margin-bottom: 36px;
        }

        .page-heading h1 {
            font-family: 'Syne', sans-serif;
            font-size: 32px;
            font-weight: 800;
            color: var(--text-primary);
            letter-spacing: -0.5px;
        }

        .page-heading p {
            color: var(--text-secondary);
            font-size: 15px;
            margin-top: 6px;
        }

        /* ── PROFILE HERO CARD ── */
        .profile-hero {
            background: linear-gradient(135deg, #2a1f4e 0%, #1a1a2e 60%, var(--bg-card) 100%);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 36px 40px;
            display: flex;
            align-items: center;
            gap: 28px;
            margin-bottom: 20px;
            position: relative;
            overflow: hidden;
        }

        .profile-hero::before {
            content: '';
            position: absolute;
            top: -40px;
            right: -40px;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(124,92,191,0.18) 0%, transparent 70%);
            pointer-events: none;
        }

        .avatar {
            width: 88px;
            height: 88px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent-purple) 0%, #5b3fa0 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Syne', sans-serif;
            font-size: 36px;
            font-weight: 800;
            color: white;
            flex-shrink: 0;
            box-shadow: 0 0 0 3px rgba(124,92,191,0.25), 0 8px 24px rgba(124,92,191,0.3);
        }

        .hero-info h2 {
            font-family: 'Syne', sans-serif;
            font-size: 24px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 4px;
        }

        .hero-info .email {
            color: var(--text-secondary);
            font-size: 14px;
        }

        .hero-info .joined-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 12px;
            background: var(--accent-purple-glow);
            border: 1px solid rgba(124,92,191,0.3);
            color: var(--accent-purple-bright);
            font-size: 12px;
            font-weight: 500;
            padding: 5px 12px;
            border-radius: 20px;
        }

        .hero-info .joined-badge::before {
            content: '✦';
            font-size: 10px;
        }

        /* ── GRID LAYOUT ── */
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
        }

        /* ── CARDS ── */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 28px 32px;
            transition: border-color 0.2s;
        }

        .card:hover {
            border-color: var(--border-hover);
        }

        .card-title {
            font-family: 'Syne', sans-serif;
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 20px;
        }

        /* ── DETAIL ROWS ── */
        .detail-row {
            display: flex;
            flex-direction: column;
            gap: 4px;
            padding: 14px 0;
            border-bottom: 1px solid var(--border);
        }

        .detail-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .detail-row:first-of-type {
            padding-top: 0;
        }

        .detail-label {
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        .detail-value {
            font-size: 15px;
            color: var(--text-primary);
            font-weight: 400;
        }

        .detail-value.mono {
            font-family: 'Courier New', monospace;
            font-size: 13px;
            color: var(--text-secondary);
        }

        /* ── SECURITY CARD ── */
        .security-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 28px 32px;
            margin-bottom: 20px;
            transition: border-color 0.2s;
        }

        .security-card:hover {
            border-color: var(--border-hover);
        }

        .security-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .security-header .card-title {
            margin-bottom: 0;
        }

        .security-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 0;
            border-bottom: 1px solid var(--border);
        }

        .security-row:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }

        .security-row-info h4 {
            font-size: 15px;
            font-weight: 500;
            color: var(--text-primary);
            margin-bottom: 3px;
        }

        .security-row-info p {
            font-size: 13px;
            color: var(--text-secondary);
        }

        /* ── BUTTONS ── */
        .btn {
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            font-weight: 500;
            padding: 9px 20px;
            border-radius: 9px;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .btn-ghost {
            background: transparent;
            color: var(--text-secondary);
            border: 1px solid var(--border);
        }

        .btn-ghost:hover {
            background: var(--bg-card-hover);
            color: var(--text-primary);
            border-color: rgba(255,255,255,0.15);
        }

        .btn-primary {
            background: var(--accent-purple);
            color: white;
        }

        .btn-primary:hover {
            background: var(--accent-purple-bright);
            box-shadow: 0 4px 16px rgba(124,92,191,0.35);
            transform: translateY(-1px);
        }

        .btn-blue {
            background: rgba(91,156,246,0.12);
            color: var(--blue);
            border: 1px solid rgba(91,156,246,0.2);
        }

        .btn-blue:hover {
            background: rgba(91,156,246,0.2);
            border-color: rgba(91,156,246,0.4);
        }

        /* ── STATUS DOT ── */
        .status-dot {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 13px;
            color: var(--green);
        }

        .status-dot::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 6px var(--green);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.4; }
        }

        /* ── EDIT PROFILE FOOTER ── */
        .actions-row {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 8px;
        }

        /* ── FADE IN ── */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        .page-heading  { animation: fadeUp 0.35s ease both; }
        .profile-hero  { animation: fadeUp 0.4s ease 0.05s both; }
        .grid-2        { animation: fadeUp 0.4s ease 0.1s both; }
        .security-card { animation: fadeUp 0.4s ease 0.15s both; }
        .actions-row   { animation: fadeUp 0.4s ease 0.2s both; }

        /* ── RESPONSIVE ── */
        @media (max-width: 640px) {
            .navbar { padding: 0 20px; }
            .page   { padding: 28px 16px 0; }
            .grid-2 { grid-template-columns: 1fr; }
            .profile-hero { flex-direction: column; text-align: center; }
            .security-header { flex-direction: column; align-items: flex-start; gap: 12px; }
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <header class="navbar">
        <div class="navbar-logo"><span>D</span>rop</div>
        <nav class="navbar-nav">
            <a href="/api/user/dashboard">Dashboard</a>
            <a href="/api/user/profile" class="active">Profile</a>
            <form action="/api/auth/logout" method="POST" style="display:inline;">
                <button type="submit" class="logout-btn">Logout</button>
            </form>
        </nav>
    </header>

    <main class="page">

        <!-- PAGE HEADING -->
        <div class="page-heading">
            <h1>Your Profile</h1>
            <p>Manage your personal information and account security.</p>
        </div>

        <!-- PROFILE HERO -->
        <div class="profile-hero">
            <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
            <div class="hero-info">
                <h2><%= user.name %></h2>
                <div class="email"><%= user.email %></div>
                <div class="joined-badge">
                    Member since <%= user.createdAt ? new Date(user.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long' }) : 'N/A' %>
                </div>
            </div>
        </div>

        <!-- TWO-COLUMN GRID -->
        <div class="grid-2">

            <!-- Personal Info -->
            <div class="card">
                <div class="card-title">Personal Info</div>

                <div class="detail-row">
                    <div class="detail-label">Full Name</div>
                    <div class="detail-value"><%= user.name %></div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Email Address</div>
                    <div class="detail-value"><%= user.email %></div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Account Created</div>
                    <div class="detail-value">
                        <%= user.createdAt ? new Date(user.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : 'N/A' %>
                    </div>
                </div>
            </div>

            <!-- Account Details -->
            <div class="card">
                <div class="card-title">Account Details</div>

                <div class="detail-row">
                    <div class="detail-label">User ID</div>
                    <div class="detail-value mono"><%= user._id %></div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Account Status</div>
                    <div class="detail-value">
                        <span class="status-dot">Active</span>
                    </div>
                </div>
                <div class="detail-row">
                    <div class="detail-label">Role</div>
                    <div class="detail-value">Standard User</div>
                </div>
            </div>

        </div>

        <!-- SECURITY CARD -->
        <div class="security-card">
            <div class="security-header">
                <div class="card-title">Security Settings</div>
            </div>

            <div class="security-row">
                <div class="security-row-info">
                    <h4>Password</h4>
                    <p>Last changed — keep it strong and unique.</p>
                </div>
                <button class="btn btn-blue">Change Password</button>
            </div>

            <div class="security-row">
                <div class="security-row-info">
                    <h4>Two-Factor Authentication</h4>
                    <p>Add an extra layer of protection to your account.</p>
                </div>
                <button class="btn btn-ghost">Enable 2FA</button>
            </div>

            <div class="security-row">
                <div class="security-row-info">
                    <h4>Active Sessions</h4>
                    <p>Manage devices that are currently logged in.</p>
                </div>
                <button class="btn btn-ghost">View Sessions</button>
            </div>
        </div>

        <!-- ACTIONS -->
        <div class="actions-row">
            <button class="btn btn-ghost">Cancel</button>
            <button class="btn btn-primary">Edit Profile</button>
        </div>

    </main>

</body>
</html>
