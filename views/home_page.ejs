<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DROP | Home</title>

    <!-- Tailwind CDN (optional, remove if not using Tailwind yet) -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-800 text-gray-900">

    <!-- NAVBAR -->
    <nav class="bg-white shadow-md">
        <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
            <h1 class="text-2xl font-bold tracking-wide">DROP</h1>

            <ul class="flex space-x-6 text-lg">
                <li><a href="/" class="hover:text-blue-600">Home</a></li>
                <li><a href="/api/auth/login" class="hover:text-blue-600">Login</a></li>
                <li><a href="/api/auth/register" class="hover:text-blue-600">Sign Up</a></li>
            </ul>
        </div>
    </nav>

    <!-- HERO SECTION -->
    <section class="max-w-6xl mx-auto px-4 mt-16 text-center">
        <h2 class="text-5xl font-extrabold mb-6">Welcome to DROP</h2>
        <p class="text-xl text-gray-700 max-w-2xl mx-auto">
            DROP helps you track your goals, habits, and progress all in one place.
            Stay consistent, stay disciplined, and DROP the excuses.
        </p>

        <a href="/api/auth/register"
           class="mt-8 inline-block bg-blue-600 text-white px-8 py-3 text-lg rounded-lg shadow hover:bg-blue-700 transition">
            Get Started
        </a>
    </section>

    <!-- FEATURES SECTION -->
    <section class="max-w-6xl mx-auto px-4 mt-24 grid grid-cols-1 md:grid-cols-3 gap-10">

        <div class="bg-white rounded-xl shadow p-8 text-center">
            <h3 class="text-2xl font-semibold mb-4">Set Goals</h3>
            <p class="text-gray-600">
                Create personal goals and track them with real-time insights.
            </p>
        </div>

        <div class="bg-white rounded-xl shadow p-8 text-center">
            <h3 class="text-2xl font-semibold mb-4">Track Progress</h3>
            <p class="text-gray-600">
                Monitor your daily, weekly, and monthly progress easily.
            </p>
        </div>

        <div class="bg-white rounded-xl shadow p-8 text-center">
            <h3 class="text-2xl font-semibold mb-4">Stay Motivated</h3>
            <p class="text-gray-600">
                Visualize your journey and stay motivated every day.
            </p>
        </div>

    </section>

    <!-- FOOTER -->
    <footer class="mt-24 py-6 text-center text-gray-600">
        <p>© <%= new Date().getFullYear() %> DROP. All Rights Reserved.</p>
    </footer>

</body>
</html>
