<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>DROP | Sign Up</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

    <!-- NAVBAR -->
    <nav class="bg-white shadow-md">
        <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
            <h1 class="text-2xl font-bold tracking-wide">DROP</h1>
            <ul class="flex space-x-6 text-lg">
                <li><a href="/" class="hover:text-blue-600">Home</a></li>
                <li><a href="/login" class="hover:text-blue-600">Login</a></li>
            </ul>
        </div>
    </nav>

    <!-- REGISTER FORM -->
    <div class="flex justify-center mt-20">
        <div class="bg-white p-10 rounded-xl shadow-md w-full max-w-md">

            <h2 class="text-3xl font-bold text-center mb-6">Create your DROP account</h2>

            <!-- Display error message if provided -->
            <% if (typeof error !== 'undefined') { %>
                <p class="text-red-600 text-center mb-4"><%= error %></p>
            <% } %>

            <form action="/register" method="POST" class="space-y-5">

                <div>
                    <label class="block mb-1 font-medium">Email</label>
                    <input 
                        type="email"
                        name="email"
                        required
                        class="w-full border border-gray-300 px-4 py-2 rounded-lg focus:outline-none focus:ring focus:ring-blue-300"
                        placeholder="Enter your email"
                    />
                </div>

                <div>
                    <label class="block mb-1 font-medium">Password</label>
                    <input 
                        type="password"
                        name="password"
                        required
                        class="w-full border border-gray-300 px-4 py-2 rounded-lg focus:outline-none focus:ring focus:ring-blue-300"
                        placeholder="Enter a strong password"
                    />
                </div>

                <div>
                    <label class="block mb-1 font-medium">Confirm Password</label>
                    <input 
                        type="password"
                        name="confirmPassword"
                        required
                        class="w-full border border-gray-300 px-4 py-2 rounded-lg focus:outline-none focus:ring focus:ring-blue-300"
                        placeholder="Confirm your password"
                    />
                </div>

                <button 
                    type="submit"
                    class="w-full bg-blue-600 text-white py-2 rounded-lg text-lg font-semibold hover:bg-blue-700 transition">
                    Sign Up
                </button>

            </form>

            <p class="text-center text-gray-700 mt-6">
                Already have an account?
                <a href="/login" class="text-blue-600 hover:underline">Login</a>
            </p>

        </div>
    </div>

</body>
</html>
